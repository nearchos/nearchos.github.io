<+><!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\" lang=\"en\">\r\n<head>\r\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<title>Nearchos Paspallis: publications &mdash; Professor in Mobile and Distributed Systems @ UCLan Cyprus</title>\r\n<link href=\"style.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n</head>\r\n\r\n<body id=\"onecolumn\">\r\n\r\n<div id=\"container\">\r\n    <div class=\"wrapper\">\r\n      <div id=\"header\">\r\n        <div class=\"wrapper\">\r\n\r\n<img src=\"UCLan_Cyprus_logo.png\" alt=\"University of Central Lancashire (UCLAN) &mdash; Cyprus\" align=\"right\" border=\"0\" width=\"250\" style=\"margin-right: 10px;\"/>\r\n\r\n          <h1 id=\"page-title\"><div id=\"g_title\"><b>Nearchos Paspallis</b></div></h1>\r\n\t\t  <h2>\r\n          Professor in Mobile and Distributed Systems\r\n\t\t  <br/>\r\n\t\t  <a href=\"http://www.uclancyprus.ac.cy\">UCLan Cyprus</a>\r\n\t\t  </h2>\r\n\t\t  <br/>\r\n\t\t</div>\r\n\r\n          <div style=\"clear: both;\"></div>\r\n          <p class=\"description\">\r\n\t      <div id=\"g_description\">\r\n\t\t  <a href=\"overview.html\">Overview</a> | <a href=\"teaching.html\">Teaching</a> | <a href=\"research.html\">Research</a> | <a href=\"software_data.html\">Software &amp; Data</a> | <a href=\"curriculumvitae.html\">Curriculum Vitae</a> | Publications | <a href=\"massmedia.html\">Mass media</a>\r\n  \t      </div>\r\n      \t  </p>\r\n\r\n          <div style=\"clear: both\"></div>\r\n        </div>\r\n      </div>\r\n\r\n<h2>Publications</h2>\r\n\r\n<p>\r\nMy publications are also indexed in\r\n<a href=\"http://orcid.org/0000-0002-2636-7973\" target=\"_blank\">orcid</a>,\r\n<a href=\"http://clok.uclan.ac.uk/profile/4906\" target=\"_blank\">CLoK</a>,\r\n<a href=\"http://www.